@model List<Product>
<h1>Product list</h1>
<table class="table">
    <thead>
    <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Price</th>
        <th>Quantity</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <th>@item.Id</th>
            <th>@item.Name</th>
            <th>@item.Price</th>
            <th>
                <a asp-controller = "Products" asp-action="Edit" asp-route-id="@item.Id" class="mb-lg-3">Edit</a>
                <a asp-action = "Delete" asp-route-id="@item.Id">Delete</a>
            </th>
        </tr>
    }
    </tbody>
</table>