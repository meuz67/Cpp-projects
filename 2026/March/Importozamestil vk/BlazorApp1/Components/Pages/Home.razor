@page "/"
@using BlazorApp1.Components.Layout.ContactComponents
<ContactList contacts="contacts"></ContactList>
@code{
    private List<Contact> contacts;
    private bool displayEmail = false;
    private Dictionary<string, object> MyTextBox = new Dictionary<string, object>()
    {
    {"placeholder", "bem"},
    {"type",  "checkbox"},
    {"disabled", "disabled"}
    };

    protected async override Task OnInitializedAsync()
    {
        await Task.Delay(5000);
        contacts = new List<Contact>()
        {
            new Contact()
            {
                FirstName = "John",
                LastName = "Thomas",
                Email = "John@gmail.com"
            },
            new Contact()
            {
                FirstName = "Peter",
                LastName = "Bob",
                Email = "PeterBob@gmail.com"
            },
            new Contact()
            {
                FirstName = "George",
                LastName = "David",
                Email = "George@gmail.com"
            }
        };
        base.OnInitializedAsync();
    }
    private void DeleteContact(Contact c)
    {
        contacts.Remove(c);
    }
}